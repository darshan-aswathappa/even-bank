# ============================================================================
# Even Bank backend — environment. Copy to .env for local dev.
# In production, set these via your platform's secret manager (never commit).
# ============================================================================

# --- Core ---
PORT=8787
# Public HTTPS origin of THIS backend (magic-link URLs + Plaid webhook target).
PUBLIC_BASE_URL=http://localhost:8787
# Comma-separated allowed CORS origins (glasses app + onboarding). NEVER "*".
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8787

# --- Database (Postgres) ---
DATABASE_URL=postgres://evenbank:evenbank@localhost:5432/evenbank

# --- Secrets ---
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
KEK_BASE64=
# >= 32 random chars for the onboarding session cookie. openssl rand -base64 32
SESSION_SECRET=

# --- Plaid (blank -> mock mode; filled -> live) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# --- Email (magic-link). Blank RESEND_API_KEY -> links are logged to console. ---
RESEND_API_KEY=
EMAIL_FROM=Even Bank <onboarding@example.com>

# Force mock mode even if Plaid keys are present ("true" to force).
USE_MOCK=
