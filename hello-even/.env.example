# Frontend (glasses app) config. Copy to .env for local dev.
# In dev, "/api" is proxied to the backend by vite.config.ts (no CORS).
# In a packaged build, set this to your real backend origin (whitelisted in app.json).
VITE_API_BASE_URL=/api

# Auth is now a device token obtained via on-glasses pairing (no static key).

# How often to re-fetch balance/transactions, in milliseconds.
VITE_REFRESH_MS=60000
